---
import Layout from '../layouts/Page.astro';
import HeroSection from '../components/heros/HeroSection.astro';
import raiContent from '../../public/cms/ratesandinsurance.json';
import CtaGeneral from '../components/CtaGeneral.astro';
import InfoCard from '../components/InfoCard.astro';
import CustomerQuoteSection from '../components/sections/CustomerQuoteSection.astro';
import Container from '../components/Container.astro';

const seo = {
	title: 'Rates and Insurance | Empowered Healing Counseling — Meaghan Trezza, LMHC',
	description: 'Session rates, accepted insurance, and payment options at Empowered Healing Counseling.',
};

const medicalInsuranceLines = raiContent.medicalInsurance.split('\n\n');

const individualRates = [
	{
		title: '50 minute session',
		price: '$150',
		tags: ['Individual', 'Somatic Experiencing'],
	},
	{
		title: '90 minute intake',
		price: '$200',
		tags: ['Individual', 'Extended assessment'],
	},
];

const couplesRates = [
	{
		title: 'Couples intake (90 min)',
		price: '$230',
		tags: ['Private pay only'],
	},
	{
		title: 'Couples session (50 min)',
		price: '$180',
		tags: ['Private pay only'],
	},
];
---

<Layout {seo}>
	<HeroSection>
		<div slot="text-container">
			<span class="eyebrow">Logistics</span>
			<h1>Rates &amp; Insurance</h1>
			<p>Plainly. So there are no surprises in the first session.</p>
		</div>
		<picture slot="image-container">
			<img
				width="828"
				height="414"
				id="rai-hero"
				src="/assets/images/mountainforest.webp"
				alt="Pacific Northwest mountain forest in soft daylight"
				loading="eager"
			/>
		</picture>
	</HeroSection>

	<CustomerQuoteSection
		quoteText={raiContent.quote}
		customerName={raiContent.quoteAuthor}
	/>

	<InfoCard iconName="mdi:phone-message-outline">
		<h2 slot="card__title">Phone consultation</h2>
		<p slot="card__body">{raiContent.phoneConsultation}</p>
	</InfoCard>

	<section class="rates">
		<Container narrow>
			<div class="rates__header">
				<span class="eyebrow">Sessions</span>
				<h2 class="rates__title">Individual rates</h2>
			</div>
			<ul class="rates__list">
				{individualRates.map((r) => (
					<li class="rates__row">
						<div class="rates__name">
							<h3>{r.title}</h3>
							<div class="rates__tags">
								{r.tags.map((t) => <span class="rates__tag">{t}</span>)}
							</div>
						</div>
						<div class="rates__price">{r.price}</div>
					</li>
				))}
			</ul>
		</Container>
	</section>

	<section class="rates">
		<Container narrow>
			<div class="rates__header">
				<span class="eyebrow">Couples</span>
				<h2 class="rates__title">Couples therapy rates</h2>
			</div>
			<ul class="rates__list">
				{couplesRates.map((r) => (
					<li class="rates__row">
						<div class="rates__name">
							<h3>{r.title}</h3>
							<div class="rates__tags">
								{r.tags.map((t) => <span class="rates__tag rates__tag--private">{t}</span>)}
							</div>
						</div>
						<div class="rates__price">{r.price}</div>
					</li>
				))}
			</ul>
		</Container>
	</section>

	<InfoCard iconName="mdi:file-document-outline">
		<h2 slot="card__title">Medical insurance</h2>
		<Fragment slot="card__body">
			{medicalInsuranceLines.map((line) => <p>{line}</p>)}
		</Fragment>
	</InfoCard>

	<InfoCard iconName="mdi:credit-card-outline">
		<h2 slot="card__title">Credit cards &amp; HSA</h2>
		<p slot="card__body">{raiContent.payments}</p>
	</InfoCard>

	<InfoCard iconName="mdi:cancel">
		<h2 slot="card__title">Cancellation policy</h2>
		<p slot="card__body">{raiContent.cancelationPolicy}</p>
	</InfoCard>

	<CtaGeneral />
</Layout>

<style>
	.rates {
		margin: var(--gap-section) auto;
	}

	.rates__header {
		margin: 0 0 1.5rem;
	}

	.rates__title {
		font-size: var(--step-3);
		font-weight: 500;
		margin: 0;
	}

	.rates__list {
		list-style: none;
		margin: 0;
		padding: 0;
		border-top: 1px solid var(--line);
	}

	.rates__row {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 1.5rem;
		align-items: center;
		padding: 1.5rem 0;
		border-bottom: 1px solid var(--line);
	}

	.rates__name h3 {
		font-size: var(--step-2);
		font-weight: 500;
		margin: 0 0 0.4rem;
	}

	.rates__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}

	.rates__tag {
		display: inline-block;
		font-size: var(--step--1);
		padding: 0.2rem 0.65rem;
		border-radius: var(--radius-pill);
		background: var(--paper-2);
		color: var(--ink-muted);
		letter-spacing: 0.02em;
	}

	.rates__tag--private {
		background: var(--clay-soft);
		color: var(--clay-ink);
	}

	.rates__price {
		font-family: var(--font-display);
		font-size: var(--step-4);
		font-weight: 500;
		color: var(--clay-deep);
		letter-spacing: -0.02em;
		font-variation-settings: 'opsz' 60, 'SOFT' 30;
		line-height: 1;
	}

	@media (max-width: 560px) {
		.rates__row {
			grid-template-columns: 1fr;
			gap: 0.5rem;
		}

		.rates__price {
			font-size: var(--step-3);
		}
	}
</style>
