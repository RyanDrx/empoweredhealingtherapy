---
import ContactForm from '../components/forms/ContactForm.astro';
import Layout from '../layouts/Page.astro';
import Container from '../components/Container.astro';
import ContactHero from '../components/ContactHero.astro';

const seo = {
	title: 'Contact | Empowered Healing Counseling — Meaghan Trezza, LMHC',
	description:
		'Contact Empowered Healing Counseling, Meaghan Trezza, LMHC. Telehealth and in-person therapy in Tacoma, WA.',
};
---

<Layout {seo}>
	<section class="contact-page">
		<Container>
			<div class="contact-page__grid">
				<ContactHero />
				<div class="contact-page__form">
					<ContactForm />
				</div>
			</div>
		</Container>
	</section>
</Layout>

<style>
	.contact-page {
		padding: clamp(2.5rem, 6vw, 5rem) 0 var(--gap-section);
	}

	.contact-page__grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: clamp(2rem, 6vw, 4.5rem);
		align-items: start;
	}

	@media (max-width: 900px) {
		.contact-page__grid {
			grid-template-columns: 1fr;
			gap: 2.5rem;
		}
	}
</style>
