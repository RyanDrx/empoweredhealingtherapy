---
import Layout from '../layouts/Page.astro';
import HeroSection from '../components/heros/HeroSection.astro';
import aboutContent from '../../public/cms/about.json';
import Icon from '../components/Icon.astro';
import CtaGeneral from '../components/CtaGeneral.astro';
import CustomerQuoteSection from '../components/sections/CustomerQuoteSection.astro';
import StickyTextImageSection from '../components/sections/StickyTextImageSection.astro';
import Container from '../components/Container.astro';

const seo = {
	title: 'About | Empowered Healing Counseling — Meaghan Trezza, LMHC',
	description:
		'About Meaghan Trezza, LMHC. Licensed Mental Health Counselor in Washington state. Specializing in trauma, anxiety, somatic experiencing, and more.',
};

const credentials = [
	{
		icon: 'mdi:school-outline',
		label: 'Education',
		body: aboutContent.education,
	},
	{
		icon: 'mdi:certificate-outline',
		label: 'License',
		body: `Licensed Mental Health Counselor in Washington state. ${aboutContent.licenseNumber}`,
	},
	{
		icon: 'mdi:brain',
		label: 'Specialized training',
		body: aboutContent.training,
	},
];

const aboutParagraphs = aboutContent.aboutContent.split('\n\n');
const introParagraphs: string[] = [];
const tailParagraphs: string[] = [];
const specializations: string[] = [];
let sawList = false;

for (const para of aboutParagraphs) {
	if (!para.trim()) continue;

	if (para.includes('\t•\t')) {
		for (const line of para.split('\n')) {
			if (line.includes('\t•\t')) {
				specializations.push(line.replace('\t•\t', '').trim());
			}
		}
		sawList = true;
		continue;
	}

	if (sawList) {
		tailParagraphs.push(para);
	} else {
		introParagraphs.push(para);
	}
}
---

<Layout {seo}>
	<HeroSection>
		<div slot="text-container">
			<span class="eyebrow">About</span>
			<h1>Meaghan Trezza, LMHC</h1>
			<p>{aboutContent.aboutBlurb}</p>
		</div>
		<picture slot="image-container">
			<img
				width="828"
				height="414"
				src="/assets/images/about-me-hero.webp"
				alt="Portrait of Meaghan Trezza"
				id="about-hero-image"
				loading="eager"
			/>
		</picture>
	</HeroSection>

	<CustomerQuoteSection
		quoteText={aboutContent.quote}
		customerName={aboutContent.quoteAuthor}
	/>

	<section class="credentials">
		<Container>
			<div class="credentials__header">
				<span class="eyebrow">Credentials</span>
				<h2 class="credentials__title">Training, license, and background.</h2>
			</div>
			<dl class="credentials__list">
				{credentials.map((c) => (
					<div class="credentials__item">
						<dt>
							<Icon name={c.icon} width="22" height="22" />
							<span>{c.label}</span>
						</dt>
						<dd>{c.body}</dd>
					</div>
				))}
			</dl>
		</Container>
	</section>

	<StickyTextImageSection>
		<div slot="text-container">
			<span class="eyebrow">In my own words</span>
			<h2>A little bit about me</h2>
			{introParagraphs.map((p) => (
				<p>{p}</p>
			))}

			{specializations.length > 0 && (
				<div class="specializations">
					<h3>I specialize in working with</h3>
					<ul>
						{specializations.map((item) => (
							<li>{item}</li>
						))}
					</ul>
				</div>
			)}

			{tailParagraphs.map((p) => (
				<p>{p}</p>
			))}
		</div>
		<picture slot="image-container">
			<img
				width="800"
				height="800"
				src="/assets/images/home-portrait.webp"
				alt="Meaghan in her therapy office"
			/>
		</picture>
	</StickyTextImageSection>

	<section class="basil">
		<Container narrow>
			<div class="basil__grid">
				<picture class="basil__image">
					<img
						src="/assets/images/basil.webp"
						alt="Basil the therapy dog"
						width="400"
						height="400"
					/>
				</picture>
				<div class="basil__text">
					<span class="eyebrow">My co-therapist</span>
					<h2>Basil</h2>
					<p>
						Basil often joins me in the office for in-person sessions. She's
						in training as a therapy dog and tends to be a breath of fresh air
						on the harder days. She enjoys belly rubs, long naps, and her
						beloved lamb chop toy.
					</p>
				</div>
			</div>
		</Container>
	</section>

	<CtaGeneral />
</Layout>

<style>
	.credentials {
		margin: var(--gap-section) auto;
	}

	.credentials__header {
		margin: 0 0 2rem;
		max-width: 38rem;
	}

	.credentials__title {
		font-size: var(--step-4);
		margin: 0;
		font-weight: 500;
	}

	.credentials__list {
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0;
		border-top: 1px solid var(--line);
		border-bottom: 1px solid var(--line);
	}

	.credentials__item {
		padding: 1.75rem 1.5rem 1.75rem 0;
	}

	.credentials__item + .credentials__item {
		border-left: 1px solid var(--line);
		padding-left: 1.5rem;
	}

	.credentials__item dt {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-family: var(--font-body);
		font-size: var(--step--1);
		font-weight: 600;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--clay-deep);
		margin: 0 0 0.6rem;
	}

	.credentials__item dt :global(iconify-icon) {
		color: var(--clay-deep);
	}

	.credentials__item dd {
		margin: 0;
		font-size: var(--step-0);
		line-height: 1.6;
		color: var(--ink);
	}

	.specializations {
		margin-top: 2.5rem;
		padding-top: 1.75rem;
		border-top: 1px solid var(--line);
	}

	.specializations h3 {
		font-family: var(--font-body);
		font-size: var(--step-0);
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--ink-muted);
		margin: 0 0 1.25rem;
	}

	.specializations ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 0.5rem 2rem;
	}

	.specializations li {
		position: relative;
		padding-left: 1.25rem;
		font-size: var(--step-0);
		color: var(--ink);
		line-height: 1.5;
	}

	.specializations li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.65em;
		width: 0.5rem;
		height: 1px;
		background: var(--clay);
	}

	.basil {
		margin: var(--gap-section) auto;
	}

	.basil__grid {
		display: grid;
		grid-template-columns: 1fr 1.4fr;
		gap: clamp(1.5rem, 4vw, 3rem);
		align-items: center;
	}

	.basil__image img {
		width: 100%;
		max-width: 22rem;
		aspect-ratio: 1;
		object-fit: cover;
		border-radius: var(--radius-md);
		display: block;
	}

	.basil__text h2 {
		font-size: var(--step-4);
		font-weight: 500;
		margin: 0 0 0.75rem;
	}

	.basil__text p {
		font-size: var(--step-1);
		line-height: 1.6;
		color: var(--ink);
		margin: 0;
		max-width: 36ch;
	}

	@media (max-width: 900px) {
		.credentials__list {
			grid-template-columns: 1fr;
		}

		.credentials__item + .credentials__item {
			border-left: none;
			border-top: 1px solid var(--line);
			padding-left: 0;
		}

		.credentials__item {
			padding: 1.5rem 0;
		}
	}

	@media (max-width: 720px) {
		.specializations ul {
			grid-template-columns: 1fr;
		}

		.basil__grid {
			grid-template-columns: 1fr;
		}

		.basil__image img {
			max-width: 100%;
		}
	}
</style>
