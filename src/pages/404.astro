---
import Button from '../components/buttons/Button.astro';
import Container from '../components/Container.astro';
import TextCardSection from '../components/sections/TextCardSection.astro';
import Layout from '../layouts/Page.astro';

const seo = {
	title: 'Empowered Healing Counseling | 404',
	description: 'Therapy services for individuals, couples, and families in the greater Seattle area.',
};
---

<Layout {seo}>
	<Container>
		<TextCardSection>
			<h1>404</h1>
			<h2>Page Not Found</h2>
			<div class="cta-buttons__container">
				<Button href="/">
					Return Home
				</Button>
			</div>
		</TextCardSection>
	</Container>
</Layout>

<style>
	.cta-buttons__container {
		display: flex;
		flex-wrap: wrap;
	}
	.cta-buttons__container :global(a) {
		margin-right: 1rem;
		margin-bottom: 1rem;
	}
	.code-buttons__container {
		margin: 1rem auto;
		display: flex;
		flex-wrap: wrap;
	}
	.code-buttons__container > a {
		margin-right: 1rem;
		margin-bottom: 1rem;
	}
</style>
