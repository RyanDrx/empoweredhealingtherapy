---
import Layout from '../layouts/Page.astro';
import Container from '../components/Container.astro';
import Button from '../components/buttons/Button.astro';

const seo = {
	title: 'Thank you | Empowered Healing Counseling — Meaghan Trezza, LMHC',
	description: 'Your message has been received.',
};

const hotlines = [
	{ name: 'Suicide & Crisis Lifeline', number: '988', href: 'tel:988', note: 'Call or text' },
	{ name: 'Crisis Text Line', number: 'Text HOME to 741741', href: 'sms:741741?body=HOME' },
	{ name: 'Trans Lifeline', number: '1-877-565-8860', href: 'tel:18775658860' },
	{ name: 'Trevor Lifeline (LGBTQ youth)', number: '1-866-488-7386', href: 'tel:18664887386' },
	{ name: 'Veterans Crisis Line', number: '1-800-273-8255, Press 1', href: 'tel:18002738255' },
];
---

<Layout {seo}>
	<section class="thanks">
		<Container narrow>
			<span class="eyebrow">Message received</span>
			<h1>Thank you.</h1>
			<p class="thanks__lead">
				I'll reach out as soon as I can — usually within one business day.
			</p>
			<div class="thanks__btn">
				<Button href="/" outlined>Back to home</Button>
			</div>

			<section class="hotlines">
				<h2>If you&rsquo;re in crisis</h2>
				<p class="hotlines__note">
					<strong>If you&rsquo;re in immediate danger, call 911.</strong>
					Otherwise, these lines are available 24/7.
				</p>
				<ul class="hotlines__list">
					{hotlines.map((h) => (
						<li>
							<span class="hotlines__name">{h.name}</span>
							<a class="hotlines__number" href={h.href}>{h.number}</a>
						</li>
					))}
				</ul>
			</section>
		</Container>
	</section>
</Layout>

<style>
	.thanks {
		padding: clamp(3rem, 8vw, 6rem) 0;
	}

	.thanks h1 {
		font-size: var(--step-5);
		font-weight: 500;
		margin: 0.25rem 0 1rem;
	}

	.thanks h1::after {
		content: '';
		display: block;
		width: 2.5rem;
		height: 3px;
		background: var(--clay);
		margin-top: 1.25rem;
	}

	.thanks__lead {
		font-size: var(--step-2);
		font-family: var(--font-display);
		font-style: italic;
		color: var(--ink-muted);
		max-width: 36ch;
		margin: 0 0 1.75rem;
		font-variation-settings: 'opsz' 36, 'SOFT' 50;
	}

	.thanks__btn {
		margin-bottom: 4rem;
	}

	.hotlines {
		margin-top: 3rem;
		padding-top: 2.5rem;
		border-top: 1px solid var(--line);
	}

	.hotlines h2 {
		font-size: var(--step-3);
		font-weight: 500;
		margin: 0 0 0.75rem;
	}

	.hotlines__note {
		color: var(--ink-muted);
		font-size: var(--step-0);
		margin: 0 0 1.5rem;
	}

	.hotlines__list {
		list-style: none;
		margin: 0;
		padding: 0;
		border-top: 1px solid var(--line);
	}

	.hotlines__list li {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		padding: 0.85rem 0;
		border-bottom: 1px solid var(--line);
	}

	.hotlines__name {
		color: var(--ink);
		font-weight: 500;
	}

	.hotlines__number {
		font-family: var(--font-display);
		font-size: var(--step-1);
		font-weight: 500;
		color: var(--clay-deep);
		text-decoration: none;
		letter-spacing: -0.005em;
	}

	.hotlines__number:hover {
		text-decoration: underline;
		text-underline-offset: 0.25em;
	}

	@media (max-width: 560px) {
		.hotlines__list li {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.25rem;
		}
	}
</style>
