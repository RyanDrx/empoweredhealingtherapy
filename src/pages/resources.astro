---
import Layout from '../layouts/Page.astro';
import HeroSection from '../components/heros/HeroSection.astro';
import resourceContent from '../../public/cms/resources.json';
import CtaGeneral from '../components/CtaGeneral.astro';
import CustomerQuoteSection from '../components/sections/CustomerQuoteSection.astro';
import { Resource } from '../models/resource';
import YouTubeEmbed from '../components/core/YouTubeEmbed.astro';
import Icon from '../components/Icon.astro';
import Container from '../components/Container.astro';

const seo = {
	title: 'Resources | Empowered Healing Counseling — Meaghan Trezza, LMHC',
	description:
		'Links, readings, and short videos on trauma, anxiety, Somatic Experiencing, and more.',
};

const resources = await Astro.glob<Resource>('../../public/cms/ResourceLinks/*.json');
const videoResources = resources.filter((r) => r.resourceLink.includes('youtube') || r.youtubeLink);
const linkResources = resources.filter((r) => !(r.resourceLink.includes('youtube') || r.youtubeLink));
---

<Layout {seo}>
	<HeroSection>
		<div slot="text-container">
			<span class="eyebrow">Reading &amp; viewing</span>
			<h1>Resources</h1>
			<p>A working library — short articles and talks I return to or hand to clients.</p>
		</div>
		<picture slot="image-container">
			<img
				width="828"
				height="414"
				id="resources-hero"
				src="/assets/images/helpful-resources.webp"
				alt="A stack of dog-eared books beside a notebook"
				loading="eager"
			/>
		</picture>
	</HeroSection>

	<CustomerQuoteSection
		quoteText={resourceContent.quote}
		customerName={resourceContent.quoteAuthor}
	/>

	{videoResources.length > 0 && (
		<section class="resource-block">
			<Container>
				<div class="resource-block__header">
					<span class="eyebrow">Watch</span>
					<h2>Talks &amp; short videos</h2>
				</div>
				<div class="video-grid">
					{videoResources.map((resource: Resource) => (
						<article class="video-card">
							<div class="video-card__media">
								<YouTubeEmbed url={resource.resourceLink} />
							</div>
							<div class="video-card__body">
								<h3>{resource.title}</h3>
								<p>{resource.description}</p>
							</div>
						</article>
					))}
				</div>
			</Container>
		</section>
	)}

	{linkResources.length > 0 && (
		<section class="resource-block">
			<Container>
				<div class="resource-block__header">
					<span class="eyebrow">Read</span>
					<h2>Articles &amp; websites</h2>
				</div>
				<ul class="link-list">
					{linkResources.map((resource: Resource) => (
						<li class="link-row">
							<a href={resource.resourceLink} target="_blank" rel="noopener noreferrer">
								<div class="link-row__text">
									<h3>{resource.title}</h3>
									{resource.description && <p>{resource.description}</p>}
								</div>
								<span class="link-row__arrow" aria-hidden="true">
									<Icon name="line-md:external-link-rounded" width="22" height="22" />
								</span>
							</a>
						</li>
					))}
				</ul>
			</Container>
		</section>
	)}

	<CtaGeneral />
</Layout>

<style>
	.resource-block {
		margin: var(--gap-section) auto;
	}

	.resource-block__header {
		margin: 0 0 2rem;
		max-width: 38rem;
	}

	.resource-block__header h2 {
		font-size: var(--step-4);
		font-weight: 500;
		margin: 0;
	}

	.video-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: clamp(1.5rem, 3vw, 2.5rem);
	}

	.video-card {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.video-card__media {
		aspect-ratio: 16 / 9;
		border-radius: var(--radius-md);
		overflow: hidden;
		background: var(--paper-2);
	}

	.video-card__media :global(.youtube-embed__container) {
		width: 100%;
		height: 100%;
		margin: 0;
		border-radius: 0;
	}

	.video-card__body h3 {
		font-size: var(--step-2);
		font-weight: 500;
		margin: 0 0 0.4rem;
	}

	.video-card__body p {
		font-size: var(--step-0);
		line-height: 1.55;
		color: var(--ink-muted);
		margin: 0;
		max-width: 50ch;
	}

	.link-list {
		list-style: none;
		margin: 0;
		padding: 0;
		border-top: 1px solid var(--line);
	}

	.link-row {
		border-bottom: 1px solid var(--line);
	}

	.link-row a {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 1.5rem;
		align-items: center;
		padding: 1.5rem 0;
		text-decoration: none;
		color: var(--ink);
		transition: color var(--theme-transition);
	}

	.link-row a:hover {
		color: var(--clay-deep);
	}

	.link-row__text h3 {
		font-family: var(--font-display);
		font-size: var(--step-2);
		font-weight: 500;
		letter-spacing: -0.015em;
		margin: 0 0 0.35rem;
	}

	.link-row__text p {
		font-size: var(--step-0);
		line-height: 1.55;
		color: var(--ink-muted);
		margin: 0;
		max-width: 60ch;
	}

	.link-row__arrow :global(iconify-icon) {
		color: var(--clay);
		transition: transform var(--theme-transition);
	}

	.link-row a:hover .link-row__arrow :global(iconify-icon) {
		transform: translate(3px, -3px);
	}

	@media (max-width: 720px) {
		.video-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
