---
import FeatureCard from '../components/cards/FeatureCard.astro';
import Container from '../components/Container.astro';
import Layout from '../layouts/Page.astro';
import HomeHeroSection from '../components/heros/HomeHeroSection.astro';
import homeContent from '../../public/cms/home.json';
import CustomerQuoteSection from '../components/sections/CustomerQuoteSection.astro';
import StickyTextImageSection from '../components/sections/StickyTextImageSection.astro';
import Button from '../components/buttons/Button.astro';
import CtaGeneral from '../components/CtaGeneral.astro';
import CtaNewClients from '../components/CtaNewClients.astro';

const seo = {
	title: 'Empowered Healing Counseling — Meaghan Trezza, LMHC',
	description:
		'A licensed mental health counselor in Tacoma, WA. Somatic Experiencing, trauma, anxiety, couples, and play therapy. Queer- and neurodivergent-affirming.',
};
---

<Layout seo={seo}>
	<HomeHeroSection />

	<CustomerQuoteSection
		quoteText={homeContent.quote}
		customerName={homeContent.quoteAuthor}
	/>

	<StickyTextImageSection reversed>
		<picture slot="image-container">
			<img
				width="800"
				height="800"
				id="about-me-home"
				src="/assets/images/home-portrait.webp"
				alt="Portrait of Meaghan Trezza"
			/>
		</picture>
		<div slot="text-container" class="intro">
			<span class="eyebrow">A note from Meaghan</span>
			<h2 class="intro__title">{homeContent.introTitle}</h2>
			{homeContent.introDescription.split('\n\n').map((paragraph) => (
				<p>{paragraph}</p>
			))}
			<div class="intro__btn">
				<Button href="/about" outlined>More about me</Button>
			</div>
		</div>
	</StickyTextImageSection>

	<CtaNewClients />

	<section class="services">
		<Container>
			<div class="services__header">
				<span class="eyebrow">How sessions happen</span>
				<h2 class="services__title">In-person in Tacoma. Telehealth across Washington.</h2>
			</div>
			<div class="services__grid">
				<article class="services__item">
					<h3>Telehealth</h3>
					{homeContent.telehealth.split('\n\n').map((paragraph) => (
						<p>{paragraph}</p>
					))}
				</article>
				<article class="services__item">
					<h3>In-person</h3>
					{homeContent.inPerson.split('\n\n').map((paragraph) => (
						<p>{paragraph}</p>
					))}
				</article>
			</div>
		</Container>
	</section>

	<section class="explore">
		<Container>
			<div class="explore__header">
				<span class="eyebrow">Explore the practice</span>
				<h2 class="explore__title">A few places to start.</h2>
			</div>
			<div class="explore__grid">
				<FeatureCard
					href="/somatic-experiencing"
					title="Somatic Experiencing"
					eyebrow="Modality"
					imgSrc="/assets/images/somatic-experiencing-home"
				/>
				<FeatureCard
					href="/couples-counseling"
					title="Couples Counseling"
					eyebrow="Service"
					imgSrc="/assets/images/couples-counseling-hero"
				/>
				<FeatureCard
					href="/play-therapy"
					title="Play Therapy"
					eyebrow="Service"
					imgSrc="/assets/images/playTherapy"
				/>
				<FeatureCard
					href="/rates-and-insurance"
					title="Rates &amp; Insurance"
					eyebrow="Logistics"
					imgSrc="/assets/images/rates-and-insurance-home"
				/>
			</div>

			<ul class="explore__secondary">
				<li>
					<a href="/about">
						<span>About Meaghan</span>
						<span class="explore__arrow" aria-hidden="true">&rarr;</span>
					</a>
				</li>
				<li>
					<a href="/resources">
						<span>Resources &amp; reading</span>
						<span class="explore__arrow" aria-hidden="true">&rarr;</span>
					</a>
				</li>
				<li>
					<a href="/contact">
						<span>Contact &amp; consult</span>
						<span class="explore__arrow" aria-hidden="true">&rarr;</span>
					</a>
				</li>
			</ul>
		</Container>
	</section>

	<CtaGeneral />
</Layout>

<style>
	.intro {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.intro__title {
		font-size: var(--step-4);
		margin: 0.25rem 0 0.5rem;
		font-weight: 500;
	}

	.intro p {
		font-size: var(--step-1);
		line-height: 1.6;
		margin: 0 0 0.9rem;
	}

	.intro__btn {
		margin-top: 1.25rem;
	}

	.services {
		margin: var(--gap-section) auto;
	}

	.services__header {
		max-width: 38rem;
		margin: 0 0 2.5rem;
	}

	.services__title {
		font-size: var(--step-4);
		margin: 0;
		font-weight: 500;
		text-wrap: balance;
	}

	.services__grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: clamp(2rem, 6vw, 4rem);
		border-top: 1px solid var(--line);
		padding-top: 2.5rem;
	}

	.services__item h3 {
		font-size: var(--step-3);
		margin: 0 0 1rem;
		font-weight: 500;
	}

	.services__item h3::after {
		content: '';
		display: block;
		width: 2rem;
		height: 2px;
		background: var(--clay);
		margin-top: 0.9rem;
	}

	.services__item p {
		font-size: var(--step-0);
		line-height: 1.65;
		color: var(--ink);
		margin: 0 0 1rem;
	}

	.explore {
		margin: var(--gap-section-lg) auto var(--gap-section);
	}

	.explore__header {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
		margin-bottom: 2.5rem;
		max-width: 32rem;
	}

	.explore__title {
		font-size: var(--step-4);
		margin: 0;
		font-weight: 500;
	}

	.explore__grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: clamp(1.5rem, 3vw, 2.5rem);
	}

	.explore__secondary {
		margin: 3.5rem 0 0;
		padding: 0;
		list-style: none;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0;
		border-top: 1px solid var(--line);
	}

	.explore__secondary li {
		border-bottom: 1px solid var(--line);
	}

	.explore__secondary li + li {
		border-left: 1px solid var(--line);
	}

	.explore__secondary a {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 1.4rem 1rem;
		text-decoration: none;
		color: var(--ink);
		font-family: var(--font-display);
		font-size: var(--step-2);
		font-weight: 500;
		letter-spacing: -0.015em;
		transition: color var(--theme-transition),
			background-color var(--theme-transition);
	}

	.explore__secondary a:hover {
		color: var(--clay-deep);
		background-color: oklch(0% 0 0 / 0.02);
	}

	.explore__secondary a:hover .explore__arrow {
		transform: translateX(4px);
	}

	.explore__arrow {
		color: var(--clay);
		transition: transform var(--theme-transition);
	}

	@media (max-width: 960px) {
		.services__grid {
			grid-template-columns: 1fr;
			gap: 2.5rem;
		}

		.explore__grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 640px) {
		.explore__grid {
			grid-template-columns: 1fr;
		}

		.explore__secondary {
			grid-template-columns: 1fr;
		}

		.explore__secondary li + li {
			border-left: none;
		}
	}
</style>
