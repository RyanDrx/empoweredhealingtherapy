---
import Layout from '../layouts/Page.astro';
import HeroSection from '../components/heros/HeroSection.astro';
import seContent from '../../public/cms/somaticExperiencing.json';
import CtaGeneral from '../components/CtaGeneral.astro';
import CustomerQuoteSection from '../components/sections/CustomerQuoteSection.astro';
import StickyTextImageSection from '../components/sections/StickyTextImageSection.astro';
import TextCardSection from '../components/sections/TextCardSection.astro';

const seo = {
	title: 'Somatic Experiencing | Empowered Healing Counseling — Meaghan Trezza, LMHC',
	description:
		'Somatic Experiencing for healing trauma and PTSD. Meaghan Trezza, LMHC, is a Somatic Experiencing Practitioner in Tacoma, Washington.',
};
---

<Layout {seo}>
	<HeroSection>
		<div slot="text-container">
			<span class="eyebrow">Modality</span>
			<h1>Somatic Experiencing</h1>
			<p>A body-aware approach to trauma — listening to what the nervous system already knows.</p>
		</div>
		<picture slot="image-container">
			<img
				width="780"
				height="439"
				src="/assets/images/somatic-experiencing.webp"
				alt="Light filtering through forest, soft and steady"
				id="se-hero-image"
				loading="eager"
			/>
		</picture>
	</HeroSection>

	<CustomerQuoteSection
		quoteText={seContent.quote}
		customerName={seContent.quoteAuthor}
	/>

	<StickyTextImageSection reversed>
		<picture slot="image-container">
			<img
				width="508"
				height="508"
				src="/assets/images/somatic-experiencing-masks.webp"
				alt="Carved wooden masks — a still-life of internal states"
			/>
		</picture>
		<div slot="text-container">
			<span class="eyebrow">The approach</span>
			<h2>What is Somatic Experiencing?</h2>
			{seContent.whatIsSE.split('\n\n').map((p) => <p>{p}</p>)}
		</div>
	</StickyTextImageSection>

	<TextCardSection>
		<h2>Why Somatic Experiencing?</h2>
		{seContent.whySE.split('\n\n').map((p) => <p>{p}</p>)}
	</TextCardSection>

	<CtaGeneral />
</Layout>
