---
import Layout from '../layouts/Page.astro';
import TextAndImageHero from '../components/heros/TextAndImageHero.astro';
import TextSection from '../components/sections/TextSection.astro';
import StickyTextImageSection from '../components/sections/StickyTextImageSection.astro';
import Container from '../components/Container.astro';
import CtaGeneral from '../components/CtaGeneral.astro';

const seo = {
	title: 'Play Therapy | Empowered Healing Counseling — Meaghan Trezza, LMHC',
	description:
		"Play therapy helps children feel safe, understood, and capable through the natural language of play. Meaghan Trezza, LMHC, Tacoma, WA.",
};

const goals = [
	{ n: '01', title: 'Emotional expression', body: 'Build vocabulary for feelings before words show up.' },
	{ n: '02', title: 'Communication skills', body: 'Trust first, then the conversation about what is hard.' },
	{ n: '03', title: 'Less anxiety, less stuckness', body: 'Reduce anxiety, trauma symptoms, and behavioral challenges.' },
	{ n: '04', title: 'Stronger relationships', body: 'With parents, peers, and caregivers — at school and at home.' },
];
---

<Layout {seo}>
	<TextAndImageHero>
		<div slot="text-container">
			<span class="eyebrow">Play Therapy</span>
			<h1>Safe, understood, and capable.</h1>
			<p>A supportive space where children explore their world through the natural language of play.</p>
		</div>
		<picture slot="image-container">
			<img
				width="780"
				height="520"
				src="/assets/images/playTherapy.webp"
				alt="A child's therapy room with toys arranged on a low shelf"
				id="play-therapy-hero-image"
				loading="eager"
			/>
		</picture>
	</TextAndImageHero>

	<TextSection>
		<h2>Creating space for what isn't said yet</h2>
		<p>
			Parents often come to play therapy when their child is struggling with
			big feelings, behavioral challenges, or life changes they don't yet have
			words to explain. As a play therapist, I offer children a supportive
			space where they can express themselves through play — the natural
			language of childhood.
		</p>
		<p>
			Every behavior tells a story. My approach helps uncover what your
			child's play and actions are saying about their inner world. Using
			evidence-based play therapy techniques, I help children process
			emotions, build coping skills, and develop confidence in a way that
			feels natural to them.
		</p>
		<p>
			My work is grounded in warmth, empathy, and respect for each child's
			pace. I collaborate closely with parents, providing insight and
			guidance so you can better understand and support your child's
			emotional needs at home.
		</p>
	</TextSection>

	<StickyTextImageSection reversed>
		<picture slot="image-container">
			<img
				width="600"
				height="600"
				src="/assets/images/play-therapy-toys.webp"
				alt="Sand tray and small toys used in play therapy sessions"
			/>
		</picture>
		<div slot="text-container">
			<span class="eyebrow">The work itself</span>
			<h2>What is play therapy?</h2>
			<p>
				Play therapy is a form of psychotherapy that uses play — the way
				children naturally express thoughts and feelings — as a means of
				communication and healing. It is most often used with children
				between ages 3 and 12, but can also benefit adolescents and even
				adults in some cases.
			</p>
			<h3>Purpose</h3>
			<p>
				Play therapy helps children express emotions, resolve conflicts,
				develop problem-solving skills, and improve behavior. It provides a
				safe, supportive space where children can explore experiences they
				may not yet have the words to describe.
			</p>
		</div>
	</StickyTextImageSection>

	<TextSection>
		<h2>How it works</h2>
		<p>
			In play therapy, toys, art materials, sand trays, puppets, and games
			are used as tools for expression. I observe and engage with your child
			to understand their emotional world and guide them toward healthier
			ways of coping.
		</p>
	</TextSection>

	<section class="goals">
		<Container>
			<div class="goals__header">
				<span class="eyebrow">What we work toward</span>
				<h2 class="goals__title">Goals of play therapy.</h2>
			</div>
			<ol class="goals__list">
				{goals.map((g) => (
					<li>
						<span class="goals__num">{g.n}</span>
						<div>
							<h3>{g.title}</h3>
							<p>{g.body}</p>
						</div>
					</li>
				))}
			</ol>
			<p class="goals__summary">
				Play becomes a language — letting children process experiences and
				emotions in a developmentally appropriate way, supported by a
				trained therapist.
			</p>
		</Container>
	</section>

	<CtaGeneral />
</Layout>

<style>
	.goals {
		margin: var(--gap-section) auto;
	}

	.goals__header {
		margin: 0 0 2.25rem;
		max-width: 38rem;
	}

	.goals__title {
		font-size: var(--step-4);
		font-weight: 500;
		margin: 0;
	}

	.goals__list {
		list-style: none;
		margin: 0 0 2.5rem;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 0;
		border-top: 1px solid var(--line);
	}

	.goals__list li {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 1.25rem;
		padding: 1.75rem 2rem 1.75rem 0;
		border-bottom: 1px solid var(--line);
	}

	.goals__list li:nth-child(2n) {
		border-left: 1px solid var(--line);
		padding-left: 2rem;
		padding-right: 0;
	}

	.goals__num {
		font-family: var(--font-display);
		font-style: italic;
		font-size: var(--step-2);
		color: var(--clay);
		line-height: 1;
		padding-top: 0.1em;
	}

	.goals__list h3 {
		font-size: var(--step-2);
		font-weight: 500;
		margin: 0 0 0.4rem;
	}

	.goals__list p {
		font-size: var(--step-0);
		line-height: 1.55;
		color: var(--ink-muted);
		margin: 0;
		max-width: 36ch;
	}

	.goals__summary {
		max-width: 48rem;
		font-family: var(--font-display);
		font-style: italic;
		font-size: var(--step-2);
		line-height: 1.4;
		color: var(--ink);
		font-variation-settings: 'opsz' 36, 'SOFT' 50;
		font-weight: 400;
	}

	@media (max-width: 720px) {
		.goals__list {
			grid-template-columns: 1fr;
		}

		.goals__list li:nth-child(2n) {
			border-left: none;
			padding-left: 0;
		}

		.goals__list li {
			padding-right: 0;
		}
	}
</style>
