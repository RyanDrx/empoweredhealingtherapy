---
import Layout from '../layouts/Page.astro';
import TextAndImageHero from '../components/heros/TextAndImageHero.astro';
import TextSection from '../components/sections/TextSection.astro';
import StickyTextImageSection from '../components/sections/StickyTextImageSection.astro';
import CtaGeneral from '../components/CtaGeneral.astro';
import Container from '../components/Container.astro';

const seo = {
	title: 'Couples Counseling | Empowered Healing Counseling — Meaghan Trezza, LMHC',
	description:
		'Rebuild communication, restore connection, and strengthen your relationship. Integrating the Gottman Method and Emotionally Focused Therapy (EFT).',
};

const outcomes = [
	{ n: '01', title: 'Break painful conflict cycles', body: 'Recognize the loops you keep ending up in — and find a different exit.' },
	{ n: '02', title: 'Rebuild trust and emotional safety', body: 'Repair after rupture, and learn to trust your own signals again.' },
	{ n: '03', title: 'Deepen emotional connection', body: 'Move past surface management into the kind of closeness you started with.' },
	{ n: '04', title: 'Improve communication skills', body: 'Practical, repeatable tools you can use the next time it gets hard.' },
];
---

<Layout {seo}>
	<TextAndImageHero>
		<div slot="text-container">
			<span class="eyebrow">Couples Counseling</span>
			<h1>Rebuild communication. Restore connection.</h1>
			<p>Integrating the Gottman Method and Emotionally Focused Therapy (EFT) — two well-researched frameworks, used together.</p>
		</div>
		<picture slot="image-container">
			<img
				width="780"
				height="520"
				src="/assets/images/couples-counseling-hero.webp"
				alt="Two people sitting close in a quiet, warmly lit room"
				id="couples-counseling-hero-image"
				loading="eager"
			/>
		</picture>
	</TextAndImageHero>

	<TextSection>
		<h2>Supporting your journey together</h2>
		<p>
			Couples often seek therapy when they feel stuck in painful cycles —
			arguing about the same issues, feeling emotionally distant, or struggling
			to rebuild trust. Working with a therapist who integrates the Gottman
			Method and Emotionally Focused Therapy (EFT) offers the best of two
			highly researched and effective approaches to help couples create lasting
			change in both communication and connection.
		</p>
	</TextSection>

	<section class="outcomes">
		<Container>
			<div class="outcomes__header">
				<span class="eyebrow">What changes</span>
				<h2 class="outcomes__title">Practical skills, renewed confidence.</h2>
			</div>
			<ol class="outcomes__list">
				{outcomes.map((o) => (
					<li class="outcomes__item">
						<span class="outcomes__num">{o.n}</span>
						<div class="outcomes__body">
							<h3>{o.title}</h3>
							<p>{o.body}</p>
						</div>
					</li>
				))}
			</ol>
		</Container>
	</section>

	<section class="therapeutic-orientation">
		<Container narrow>
			<div class="therapeutic-orientation__inner">
				<span class="eyebrow eyebrow--on-dark">Approach</span>
				<h2>Therapeutic orientation</h2>
				<p>
					My theoretical orientation as a couples therapist is grounded in
					both the Gottman Method and Emotionally Focused Therapy (EFT),
					integrating empirically supported strategies with an
					attachment-based, emotionally attuned framework. This blended
					approach lets me address both the behavioral and emotional
					dimensions of relational distress while fostering sustainable,
					secure connection between partners.
				</p>
			</div>
		</Container>
	</section>

	<style is:global>
		.therapeutic-orientation .eyebrow {
			color: var(--clay-soft);
		}
	</style>

	<StickyTextImageSection>
		<picture slot="image-container">
			<img
				width="600"
				height="600"
				src="/assets/images/couples-gottman-method.webp"
				alt="Illustration of the Gottman Method's relationship structure"
				class="gottman-image"
			/>
		</picture>
		<div slot="text-container">
			<span class="eyebrow">In session</span>
			<h2>The Gottman Method</h2>
			<p>
				From the Gottman perspective, I focus on building a solid foundation
				of relational health through assessment and skill-building. I use
				Gottman interventions to help couples reduce conflict, improve
				communication, and strengthen friendship and shared meaning. The
				structured nature of this model gives partners concrete tools to
				recognize destructive patterns — criticism, defensiveness, contempt,
				stonewalling — and replace them with behaviors that promote mutual
				understanding and respect.
			</p>
		</div>
	</StickyTextImageSection>

	<CtaGeneral />
</Layout>

<style>
	.outcomes {
		margin: var(--gap-section) auto;
	}

	.outcomes__header {
		margin: 0 0 2.25rem;
		max-width: 38rem;
	}

	.outcomes__title {
		font-size: var(--step-4);
		font-weight: 500;
		margin: 0;
	}

	.outcomes__list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0;
		border-top: 1px solid var(--line);
	}

	.outcomes__item {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 1.25rem;
		padding: 1.75rem 0;
		border-bottom: 1px solid var(--line);
		padding-right: 2rem;
	}

	.outcomes__list .outcomes__item:nth-child(2n) {
		border-left: 1px solid var(--line);
		padding-left: 2rem;
		padding-right: 0;
	}

	.outcomes__num {
		font-family: var(--font-display);
		font-style: italic;
		font-weight: 400;
		font-size: var(--step-2);
		color: var(--clay);
		font-variation-settings: 'opsz' 48, 'SOFT' 100;
		line-height: 1;
		padding-top: 0.15em;
	}

	.outcomes__body h3 {
		font-size: var(--step-2);
		font-weight: 500;
		margin: 0 0 0.5rem;
	}

	.outcomes__body p {
		font-size: var(--step-0);
		line-height: 1.55;
		color: var(--ink-muted);
		margin: 0;
		max-width: 36ch;
	}

	@media (max-width: 720px) {
		.outcomes__list {
			grid-template-columns: 1fr;
		}

		.outcomes__list .outcomes__item:nth-child(2n) {
			border-left: none;
			padding-left: 0;
		}

		.outcomes__item {
			padding-right: 0;
		}
	}

	.therapeutic-orientation {
		margin: var(--gap-section) auto;
		background-color: var(--moss);
		color: oklch(96% 0.012 75);
		padding: clamp(3rem, 7vw, 5rem) 0;
	}

	.therapeutic-orientation__inner {
		max-width: 38rem;
		margin: 0 auto;
	}

	.therapeutic-orientation h2 {
		color: oklch(98% 0.012 75);
		font-size: var(--step-4);
		font-weight: 500;
		margin: 0 0 1.25rem;
	}

	.therapeutic-orientation h2::after {
		content: '';
		display: block;
		width: 2rem;
		height: 2px;
		background: oklch(85% 0.06 35);
		margin-top: 1rem;
	}

	.therapeutic-orientation p {
		color: oklch(92% 0.018 80);
		font-size: var(--step-1);
		line-height: 1.65;
		margin: 0;
		max-width: 56ch;
	}

	.eyebrow--on-dark {
		color: oklch(85% 0.06 35) !important;
	}

	.gottman-image {
		border-radius: var(--radius-md);
	}
</style>
