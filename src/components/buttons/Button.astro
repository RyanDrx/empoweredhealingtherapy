---
const { href, unelevated, outlined, customIcon, onPrimary, newTab, target } =
	Astro.props;

const Tag = href ? 'a' : 'button';
const variant = outlined ? 'btn--outlined' : unelevated ? 'btn--quiet' : 'btn--solid';
const onPrimaryClass = onPrimary ? 'btn--on-primary' : '';
---

<Tag
	class={`btn ${variant} ${onPrimaryClass}`.trim()}
	href={href}
	target={target || (newTab ? '_blank' : undefined)}
	rel={newTab ? 'noopener noreferrer' : undefined}
>
	<span class="btn__label"><slot /></span>
	{customIcon && (
		<span class="btn__icon">
			<slot name="icon" />
		</span>
	)}
</Tag>

<style>
	.btn {
		--btn-bg: var(--clay);
		--btn-fg: var(--paper);
		--btn-border: var(--clay);
		--btn-bg-hover: var(--clay-deep);
		--btn-fg-hover: var(--paper);

		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.55rem;
		min-height: 44px;
		padding: 0.78rem 1.25rem;
		margin: 0;
		font-family: var(--font-body);
		font-size: var(--step-0);
		font-weight: 600;
		line-height: 1;
		letter-spacing: -0.005em;
		color: var(--btn-fg);
		background: var(--btn-bg);
		border: 1px solid var(--btn-border);
		border-radius: var(--radius-sm);
		text-decoration: none;
		cursor: pointer;
		transition: background-color var(--theme-transition),
			color var(--theme-transition),
			border-color var(--theme-transition),
			transform var(--theme-transition);
		width: fit-content;
	}

	.btn:hover {
		background: var(--btn-bg-hover);
		color: var(--btn-fg-hover);
		border-color: var(--btn-bg-hover);
	}

	.btn:active {
		transform: translateY(1px);
	}

	.btn--outlined {
		--btn-bg: transparent;
		--btn-fg: var(--ink);
		--btn-border: var(--ink);
		--btn-bg-hover: var(--ink);
		--btn-fg-hover: var(--paper);
	}

	.btn--quiet {
		--btn-bg: transparent;
		--btn-fg: var(--ink);
		--btn-border: transparent;
		--btn-bg-hover: transparent;
		--btn-fg-hover: var(--clay-deep);
		padding-inline: 0.25rem;
	}

	.btn--quiet:hover {
		text-decoration: underline;
		text-underline-offset: 0.3em;
		text-decoration-thickness: 1px;
	}

	.btn--on-primary {
		--btn-bg: var(--paper);
		--btn-fg: var(--ink);
		--btn-border: var(--paper);
		--btn-bg-hover: var(--ink);
		--btn-fg-hover: var(--paper);
	}

	.btn__icon {
		display: inline-flex;
		align-items: center;
		transition: transform var(--theme-transition);
	}

	.btn__icon :global(svg),
	.btn__icon :global(iconify-icon) {
		width: 1.1em;
		height: 1.1em;
	}

	.btn:hover .btn__icon {
		transform: translateX(3px);
	}

	.btn:focus-visible {
		outline: 2px solid var(--clay);
		outline-offset: 3px;
	}

	@media (prefers-reduced-motion: reduce) {
		.btn,
		.btn:hover,
		.btn:hover .btn__icon {
			transition: none;
			transform: none;
		}
	}
</style>
