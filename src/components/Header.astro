---
const { navData, rightMenu } = Astro.props;
import Icon from './Icon.astro';

const pathname = new URL(Astro.request.url).pathname;
const currentSlug = pathname.endsWith('/') && pathname.length > 1
	? pathname.slice(0, -1)
	: pathname;
---

<script type="module">
	const bodyElement = document.querySelector('body');
	const menuButton = document.querySelector('#menuButton');
	const navHeader = document.querySelector('#navHeader');
	const menuButtonIconHam = document.querySelector('#menuButtonIconHam');
	const menuButtonIconClose = document.querySelector('#menuButtonIconClose');
	let scrollPosition = 0;

	menuButton.addEventListener('click', toggleMenu);

	function toggleMenu() {
		menuButtonIconHam.toggleAttribute('hidden');
		menuButtonIconClose.toggleAttribute('hidden');

		const isOpen = navHeader.hasAttribute('mobile-menu-open');

		if (isOpen) {
			menuButton.title = 'Open Main Menu';
			menuButton.setAttribute('aria-expanded', 'false');
			bodyElement.style.removeProperty('overflow');
			bodyElement.style.removeProperty('position');
			bodyElement.style.removeProperty('top');
			bodyElement.style.removeProperty('width');
			window.scrollTo(0, scrollPosition);
		} else {
			menuButton.title = 'Close Main Menu';
			menuButton.setAttribute('aria-expanded', 'true');
			scrollPosition = window.pageYOffset;
			bodyElement.style.overflow = 'hidden';
			bodyElement.style.position = 'fixed';
			bodyElement.style.top = `-${scrollPosition}px`;
			bodyElement.style.width = '100%';
		}

		navHeader.toggleAttribute('mobile-menu-open');
	}

	// subtle header state on scroll
	const onScroll = () => {
		if (window.scrollY > 8) navHeader.setAttribute('data-scrolled', 'true');
		else navHeader.removeAttribute('data-scrolled');
	};
	window.addEventListener('scroll', onScroll, { passive: true });
	onScroll();
</script>

<header
	id="navHeader"
	class={`site-header ${rightMenu ? 'site-header--right' : ''}`}
>
	<div class="site-header__inner">
		<div class="site-header__logo">
			<slot name="logo" />
		</div>

		<button
			id="menuButton"
			class="site-header__menu-btn"
			title="Open Main Menu"
			aria-controls="primary-nav"
			aria-expanded="false"
		>
			<span id="menuButtonIconHam">
				<Icon name="line-md:menu" width="32" height="32" />
			</span>
			<span id="menuButtonIconClose" hidden>
				<Icon name="line-md:close-small" width="32" height="32" />
			</span>
		</button>

		<div id="primary-nav" class="site-header__nav-wrap">
			<slot name="nav">
				{navData && (
					<nav aria-label="Primary">
						<ul>
							{navData.map((navItem) => {
								const slug =
									navItem.slug.endsWith('/') && navItem.slug.length > 1
										? navItem.slug.slice(0, -1)
										: navItem.slug;
								const isActive = currentSlug === slug;
								return (
									<li class={isActive ? 'is-active' : ''}>
										<a href={navItem.slug}>{navItem.title}</a>
									</li>
								);
							})}
							<li class="site-header__contact-li">
								<a href="/contact">Contact</a>
							</li>
						</ul>
					</nav>
				)}
			</slot>
		</div>

		<div class="site-header__action">
			<slot name="action-item" />
		</div>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 90;
		width: 100%;
		background: var(--paper);
		border-bottom: 1px solid transparent;
		transition: border-color var(--theme-transition),
			box-shadow var(--theme-transition);
	}

	.site-header[data-scrolled] {
		border-bottom-color: var(--line);
		box-shadow: 0 8px 24px -16px oklch(20% 0.05 50 / 0.18);
	}

	.site-header__inner {
		max-width: var(--w-page);
		margin: 0 auto;
		padding: 0.6rem clamp(1.25rem, 4vw, 2.5rem);
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 1.5rem;
		min-height: var(--navbar-height);
	}

	.site-header__logo {
		display: inline-flex;
		align-items: center;
	}

	.site-header__nav-wrap {
		justify-self: center;
	}

	nav {
		display: flex;
	}

	nav ul {
		display: flex;
		align-items: center;
		gap: 0.25rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	nav li a {
		display: inline-block;
		padding: 0.55rem 0.85rem;
		font-family: var(--font-body);
		font-size: var(--step--1);
		font-weight: 500;
		letter-spacing: 0.01em;
		color: var(--ink-muted);
		text-decoration: none;
		border-radius: var(--radius-xs);
		transition: color var(--theme-transition),
			background-color var(--theme-transition);
		white-space: nowrap;
	}

	nav li a:hover {
		color: var(--ink);
		background-color: oklch(0% 0 0 / 0.03);
	}

	nav li.is-active a {
		color: var(--clay-deep);
		font-weight: 600;
	}

	.site-header__contact-li {
		display: none;
		margin-left: 0.5rem;
		padding-left: 0.75rem;
		border-left: 1px solid var(--line);
	}

	.site-header__action {
		justify-self: end;
	}

	.site-header__menu-btn {
		display: none;
		appearance: none;
		background: transparent;
		border: 1px solid var(--line);
		border-radius: var(--radius-sm);
		color: var(--ink);
		padding: 0.5rem;
		cursor: pointer;
		-webkit-tap-highlight-color: transparent;
		line-height: 0;
	}

	.site-header__menu-btn :global(iconify-icon) {
		display: block;
		line-height: 0;
	}

	.site-header__menu-btn > span {
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}

	.site-header__menu-btn > span[hidden] {
		display: none;
	}

	.site-header__menu-btn:hover {
		background-color: var(--paper-2);
	}

	@media screen and (max-width: 1180px) {
		.site-header__menu-btn {
			display: inline-flex;
			justify-self: end;
			grid-column: 3;
		}

		.site-header__action {
			display: none;
		}

		.site-header__contact-li {
			display: block;
		}

		.site-header__nav-wrap {
			position: fixed;
			top: var(--navbar-height);
			left: 0;
			right: 0;
			bottom: 0;
			background: var(--paper);
			display: none;
			padding: 1.5rem 1.5rem 4rem;
			z-index: 95;
			justify-self: stretch;
			overflow-y: auto;
		}

		.site-header[mobile-menu-open] .site-header__nav-wrap {
			display: block;
			animation: menu-fade 220ms var(--ease-out-quart);
		}

		@keyframes menu-fade {
			from { opacity: 0; transform: translateY(-8px); }
			to   { opacity: 1; transform: translateY(0); }
		}

		.site-header[mobile-menu-open] nav {
			width: 100%;
			margin: 0 auto;
			max-width: var(--w-narrow);
		}

		.site-header[mobile-menu-open] nav ul {
			flex-direction: column;
			align-items: flex-start;
			width: 100%;
			gap: 0.25rem;
		}

		.site-header[mobile-menu-open] nav li {
			width: 100%;
			border-bottom: 1px solid var(--line);
		}

		.site-header[mobile-menu-open] nav li a {
			width: 100%;
			padding: 1.1rem 0.25rem;
			font-family: var(--font-display);
			font-size: var(--step-3);
			font-weight: 500;
			letter-spacing: -0.01em;
			color: var(--ink);
		}

		.site-header[mobile-menu-open] nav li.is-active a {
			color: var(--clay-deep);
		}

		.site-header__contact-li {
			border-left: none;
			padding-left: 0;
			margin-left: 0;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.site-header,
		nav li a {
			transition: none;
		}
	}
</style>
