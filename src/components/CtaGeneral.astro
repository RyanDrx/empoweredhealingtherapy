---
import Icon from './Icon.astro';
import Button from './buttons/Button.astro';
import Container from './Container.astro';
---

<section class="cta-general">
	<Container>
		<div class="cta-general__inner">
			<div class="cta-general__text">
				<h2 class="cta-general__title">Ready when you are.</h2>
				<p class="cta-general__sub">
					A free 15-minute call to see if we're a good fit. No pressure, no script.
				</p>
			</div>
			<div class="cta-general__actions">
				<Button href="/contact" customIcon>
					Book a consult
					<Fragment slot="icon">
						<Icon name="line-md:chevron-right" />
					</Fragment>
				</Button>
				<a class="cta-general__phone" href="tel:3602075773">
					<Icon name="line-md:phone-filled" width="18" height="18" />
					(360) 207-5773
				</a>
			</div>
		</div>
	</Container>
</section>

<style>
	.cta-general {
		margin: var(--gap-section-lg) auto 0;
		padding: clamp(2.5rem, 6vw, 4rem) 0 clamp(3rem, 7vw, 5rem);
		background: linear-gradient(180deg, transparent 0%, var(--clay-soft) 100%);
		border-top: 1px solid var(--line);
	}

	.cta-general__inner {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 2.5rem;
		align-items: center;
	}

	.cta-general__title {
		font-size: var(--step-4);
		margin: 0 0 0.4rem;
		font-weight: 500;
	}

	.cta-general__sub {
		font-family: var(--font-display);
		font-style: italic;
		font-size: var(--step-2);
		font-weight: 400;
		color: var(--ink-muted);
		margin: 0;
		max-width: 38ch;
	}

	.cta-general__actions {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		align-items: flex-start;
	}

	.cta-general__phone {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		font-size: var(--step--1);
		color: var(--ink-muted);
		text-decoration: none;
		letter-spacing: 0.04em;
	}

	.cta-general__phone:hover {
		color: var(--clay-deep);
	}

	@media (max-width: 720px) {
		.cta-general__inner {
			grid-template-columns: 1fr;
		}
	}
</style>
