---
import Container from '../components/Container.astro';
import Icon from './Icon.astro';

const { iconName } = Astro.props;
---

<Container narrow>
	<article class="info-row">
		<div class="info-row__icon" aria-hidden="true">
			<Icon name={iconName} width="32" height="32" />
		</div>
		<div class="info-row__body">
			<slot name="card__title" />
			<slot name="card__body" />
		</div>
	</article>
</Container>

<style>
	.info-row {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 1.5rem;
		max-width: 42rem;
		margin: var(--gap-section-sm) auto;
		padding: 1.75rem 0;
		border-top: 1px solid var(--line);
	}

	.info-row__icon :global(iconify-icon) {
		color: var(--clay-deep);
		width: 2rem;
		height: 2rem;
		display: block;
	}

	.info-row__body :global(h2) {
		font-size: var(--step-2);
		font-weight: 500;
		color: var(--ink);
		margin: 0 0 0.75rem;
	}

	.info-row__body :global(p) {
		font-size: var(--step-0);
		line-height: 1.65;
		color: var(--ink);
		margin: 0 0 1rem;
		max-width: 60ch;
	}

	.info-row__body :global(p:last-child) {
		margin-bottom: 0;
	}

	@media (max-width: 600px) {
		.info-row {
			grid-template-columns: 1fr;
			gap: 0.75rem;
		}
	}
</style>
