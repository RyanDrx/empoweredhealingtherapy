---
const { label, name, options, required } = Astro.props;
---

<div class="form-field__container">
	{label && (
		<label for={name}>
			{label}
			{required && <span class="form-field__required" aria-hidden="true">*</span>}
		</label>
	)}
	<select id={name} name={name} required={required} defaultValue="">
		<option disabled selected value="">Choose one</option>
		{options?.map((option) => (
			<option value={option}>{option}</option>
		))}
	</select>
</div>

<style>
	.form-field__container select {
		width: 100%;
	}

	.form-field__required {
		color: var(--clay-deep);
		margin-left: 0.15em;
	}
</style>
