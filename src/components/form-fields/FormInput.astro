---
const { type = 'text', label, name, placeholder, required } = Astro.props;
---

<div class="form-field__container">
	{label && (
		<label for={name}>
			{label}
			{required && <span class="form-field__required" aria-hidden="true">*</span>}
		</label>
	)}
	<input type={type} id={name} name={name} placeholder={placeholder} required={required} />
</div>

<style>
	.form-field__container input {
		width: 100%;
	}

	.form-field__required {
		color: var(--clay-deep);
		margin-left: 0.15em;
	}
</style>
