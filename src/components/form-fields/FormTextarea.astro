---
const { label, name, placeholder, rows = 4, required } = Astro.props;
---

<div class="form-field__container">
	{label && (
		<label for={name}>
			{label}
			{required && <span class="form-field__required" aria-hidden="true">*</span>}
		</label>
	)}
	<textarea id={name} name={name} placeholder={placeholder} rows={rows} required={required}></textarea>
</div>

<style>
	.form-field__container textarea {
		width: 100%;
	}

	.form-field__required {
		color: var(--clay-deep);
		margin-left: 0.15em;
	}
</style>
