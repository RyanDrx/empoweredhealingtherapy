---
import Icon from './Icon.astro';
import Button from './buttons/Button.astro';
import Container from './Container.astro';
---

<section class="cta-new-clients">
	<Container>
		<div class="cta-new-clients__inner">
			<div class="cta-new-clients__status">
				<span class="cta-new-clients__dot" aria-hidden="true"></span>
				<span>Accepting new clients</span>
			</div>
			<h2 class="cta-new-clients__title">
				A consult is the lowest-stakes way to find out if we're a fit.
			</h2>
			<p class="cta-new-clients__sub">
				Fifteen minutes on the phone. No commitment, no intake form.
			</p>
			<div class="cta-new-clients__actions">
				<Button href="/contact" customIcon>
					Schedule a consult
					<Fragment slot="icon">
						<Icon name="line-md:chevron-right" />
					</Fragment>
				</Button>
			</div>
		</div>
	</Container>
</section>

<style>
	.cta-new-clients {
		margin: var(--gap-section) auto;
	}

	.cta-new-clients__inner {
		max-width: 44rem;
		margin: 0 auto;
		padding: clamp(2rem, 5vw, 3rem) clamp(1.5rem, 4vw, 2.5rem);
		text-align: center;
		border: 1px solid var(--line);
		border-radius: var(--radius-lg);
		background: var(--paper-3);
		position: relative;
	}

	.cta-new-clients__status {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		font-size: var(--step--1);
		font-weight: 600;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--moss);
		margin-bottom: 1.25rem;
	}

	.cta-new-clients__dot {
		width: 0.5rem;
		height: 0.5rem;
		border-radius: var(--radius-pill);
		background: var(--moss);
		box-shadow: 0 0 0 4px oklch(89% 0.025 145 / 0.7);
	}

	.cta-new-clients__title {
		font-size: var(--step-3);
		font-weight: 500;
		margin: 0 0 0.5rem;
		text-wrap: balance;
		max-width: 22ch;
		margin-inline: auto;
	}

	.cta-new-clients__sub {
		color: var(--ink-muted);
		font-size: var(--step-1);
		margin: 0 auto 1.75rem;
		max-width: 36ch;
		font-family: var(--font-display);
		font-style: italic;
		font-variation-settings: 'opsz' 36, 'SOFT' 50;
	}

	.cta-new-clients__actions {
		display: flex;
		justify-content: center;
	}
</style>
