---
import Container from '../Container.astro';
---

<section class="text-card">
	<Container narrow>
		<div class="text-card__inner">
			<slot />
		</div>
	</Container>
</section>

<style>
	.text-card {
		margin: var(--gap-section) auto;
	}

	.text-card__inner {
		padding: clamp(2rem, 5vw, 3.5rem) clamp(1.5rem, 4vw, 2.5rem);
		border-top: 1px solid var(--line);
		border-bottom: 1px solid var(--line);
		max-width: 42rem;
		margin: 0 auto;
	}

	.text-card__inner :global(h1),
	.text-card__inner :global(h2) {
		font-size: var(--step-4);
		font-weight: 500;
		color: var(--ink);
		margin: 0 0 1rem;
	}

	.text-card__inner :global(h2)::after {
		content: '';
		display: block;
		width: 2rem;
		height: 2px;
		background: var(--clay);
		margin-top: 1rem;
	}

	.text-card__inner :global(p) {
		font-size: var(--step-1);
		line-height: 1.65;
		color: var(--ink);
		margin: 0 0 1rem;
	}
</style>
