---
import Container from '../Container.astro';

const {quoteText, customerName} = Astro.props;
---

<section class="customer-quote__section">
  <Container narrow>
    <blockquote>"{quoteText}"</blockquote>
    <p>&mdash; {customerName}</p>
  </Container>
</section>

  <style>
.customer-quote__section {
  margin: var(--section-margin) auto;
  padding: clamp(2rem, 6vw, 4rem) 1rem;
  background-color: var(--theme-surface-1);
  text-align: center;
  border-block: 1px solid rgba(32, 35, 33, 0.08);
}
.customer-quote__section blockquote {
  padding: 0;
  border: none;
  font-size: clamp(1.2rem, 3vw, var(--font-size-md));
  font-weight: 400;
  font-style: italic;
  line-height: 1.65;
  color: var(--theme-on-bg);
}

.customer-quote__section p {
  color: var(--theme-primary);
  font-weight: 700;
}
</style>
