---
import Container from '../Container.astro';
---

<Container>
	<section class="three-col">
		<div class="three-col__title">
			<slot name="section-title" />
		</div>

		<div class="three-col__grid">
			<div class="three-col__cell">
				<slot name="column-1-body" />
				<slot name="column-1-cta" />
			</div>
			<div class="three-col__cell">
				<slot name="column-2-body" />
				<slot name="column-2-cta" />
			</div>
			<div class="three-col__cell">
				<slot name="column-3-body" />
				<slot name="column-3-cta" />
			</div>
		</div>
	</section>
</Container>

<style>
	.three-col {
		margin: var(--gap-section) auto;
	}

	.three-col__title {
		margin: 0 0 2rem;
		max-width: 38rem;
	}

	.three-col__grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0;
		border-top: 1px solid var(--line);
	}

	.three-col__cell {
		padding: 2.25rem 1.5rem;
		border-bottom: 1px solid var(--line);
	}

	.three-col__cell + .three-col__cell {
		border-left: 1px solid var(--line);
	}

	@media (max-width: 1024px) {
		.three-col__grid {
			grid-template-columns: 1fr 1fr;
		}

		.three-col__cell + .three-col__cell {
			border-left: 1px solid var(--line);
		}

		.three-col__cell:nth-child(odd) + .three-col__cell:nth-child(even) {
			border-left: 1px solid var(--line);
		}

		.three-col__cell:nth-child(2n+1) {
			border-left: none;
		}
	}

	@media (max-width: 720px) {
		.three-col__grid {
			grid-template-columns: 1fr;
		}

		.three-col__cell + .three-col__cell {
			border-left: none;
		}

		.three-col__cell {
			padding: 2rem 0;
		}
	}
</style>
