---
import Container from '../Container.astro';

const { reversed } = Astro.props;
---

<Container>
	<section class={`sticky-section ${reversed ? 'sticky-section--reversed' : ''}`}>
		<div class="sticky-section__text">
			<div class="sticky-section__text-inner">
				<slot name="text-container" />
			</div>
		</div>
		<div class="sticky-section__image">
			<slot name="image-container" />
		</div>
	</section>
</Container>

<style>
	.sticky-section {
		margin: var(--gap-section) auto;
		display: grid;
		grid-template-columns: 7fr 5fr;
		gap: clamp(2rem, 6vw, 5rem);
		align-items: start;
	}

	.sticky-section--reversed {
		grid-template-columns: 5fr 7fr;
	}

	.sticky-section--reversed .sticky-section__text {
		order: 2;
	}

	.sticky-section__text {
		padding-top: 0.5rem;
	}

	.sticky-section__text-inner {
		max-width: 38rem;
	}

	.sticky-section__image {
		position: sticky;
		top: calc(var(--navbar-height) + 1.5rem);
		align-self: start;
	}

	.sticky-section__image :global(picture) {
		display: block;
		width: 100%;
		max-width: 32rem;
	}

	.sticky-section__image :global(img) {
		width: 100%;
		height: auto;
		max-height: 38rem;
		object-fit: cover;
		border-radius: var(--radius-md);
		display: block;
	}

	.sticky-section__text-inner :global(h2) {
		font-size: var(--step-4);
		font-weight: 500;
		color: var(--ink);
		margin: 0 0 1.25rem;
	}

	.sticky-section__text-inner :global(h2::after) {
		content: '';
		display: block;
		width: 2.5rem;
		height: 2px;
		background: var(--clay);
		margin-top: 1.1rem;
	}

	.sticky-section__text-inner :global(p) {
		font-size: var(--step-1);
		line-height: 1.6;
		color: var(--ink);
		margin: 0 0 1.2rem;
	}

	@media (max-width: 960px) {
		.sticky-section,
		.sticky-section--reversed {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.sticky-section--reversed .sticky-section__text {
			order: 2;
		}

		.sticky-section__image {
			position: static;
		}

		.sticky-section__image :global(picture) {
			max-width: 100%;
		}
	}
</style>
