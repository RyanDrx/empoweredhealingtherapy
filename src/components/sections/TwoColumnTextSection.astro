---
import Container from '../Container.astro';
---

<Container>
	<section class="two-col">
		<div class="two-col__title">
			<slot name="section-title" />
		</div>

		<div class="two-col__grid">
			<div class="two-col__cell">
				<slot name="column-1-body" />
				<slot name="column-1-cta" />
			</div>
			<div class="two-col__cell">
				<slot name="column-2-body" />
				<slot name="column-2-cta" />
			</div>
		</div>
	</section>
</Container>

<style>
	.two-col {
		margin: var(--gap-section) auto;
	}

	.two-col__title {
		margin: 0 0 2rem;
		max-width: 38rem;
	}

	.two-col__grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: clamp(1.5rem, 4vw, 3rem);
	}

	@media (max-width: 720px) {
		.two-col__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
