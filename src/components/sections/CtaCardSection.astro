---
import Container from '../Container.astro';

const { background, color } = Astro.props;
---

<Container>
	<section
		class="cta-card"
		style={background ? `--cta-bg:${background}; --cta-fg:${color};` : ''}
	>
		<div class="cta-card__inner">
			<slot />
		</div>
	</section>
</Container>

<style>
	.cta-card {
		--cta-bg: var(--paper-3);
		--cta-fg: var(--ink);
		margin: var(--gap-section) auto;
		padding: clamp(2rem, 5vw, 3.5rem) clamp(1.5rem, 4vw, 2.5rem);
		background-color: var(--cta-bg);
		color: var(--cta-fg);
		border: 1px solid var(--line);
		border-radius: var(--radius-lg);
		text-align: center;
	}

	.cta-card__inner {
		max-width: 44rem;
		margin: 0 auto;
	}
</style>
