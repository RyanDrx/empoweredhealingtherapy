---
import Container from '../Container.astro';

const { narrow, class: className } = Astro.props;
---

<Container narrow={narrow}>
	<section class:list={['prose-section', className]}>
		<slot />
	</section>
</Container>

<style>
	.prose-section {
		margin: var(--gap-section) auto;
		max-width: 38rem;
	}

	.prose-section :global(h1) {
		font-size: var(--step-5);
		font-weight: 500;
		color: var(--ink);
		margin: 0 0 1rem;
	}

	.prose-section :global(h2) {
		font-size: var(--step-4);
		font-weight: 500;
		color: var(--ink);
		margin: 0 0 1.25rem;
	}

	.prose-section :global(h2)::after {
		content: '';
		display: block;
		width: 2rem;
		height: 2px;
		background: var(--clay);
		margin-top: 1.1rem;
	}

	.prose-section :global(h3) {
		font-size: var(--step-3);
		font-weight: 500;
		color: var(--ink);
		margin: 2rem 0 0.85rem;
	}

	.prose-section :global(p) {
		font-size: var(--step-1);
		line-height: 1.65;
		color: var(--ink);
		margin: 0 0 1.1rem;
	}

	.prose-section :global(ul),
	.prose-section :global(ol) {
		margin: 1.5rem 0;
		padding-left: 1.25rem;
	}

	.prose-section :global(li) {
		font-size: var(--step-0);
		line-height: 1.65;
		color: var(--ink);
		margin-bottom: 0.5rem;
	}
</style>
