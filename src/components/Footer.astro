---
import Icon from './Icon.astro';
import Container from './Container.astro';

const { footerSocials, footerLists, copyrightName } = Astro.props;
const hasSocials = Array.isArray(footerSocials) && footerSocials.length > 0;
const hasLists = Array.isArray(footerLists) && footerLists.length > 0;
const year = new Date().getFullYear();
---

<footer class="site-footer">
	<Container>
		<div class="site-footer__top">
			<div class="site-footer__brand">
				<slot name="logo" />
				<address class="site-footer__contact">
					<a href="tel:3602075773">
						<Icon name="line-md:phone-filled" width="18" height="18" />
						(360) 207-5773
					</a>
					<a href="mailto:Meaghan@EmpoweredHealingWA.com">
						<Icon name="line-md:email" width="18" height="18" />
						Meaghan@EmpoweredHealingWA.com
					</a>
					<span class="site-footer__address">
						<Icon name="line-md:map-marker" width="18" height="18" />
						<span>
							1310 South Union Avenue<br />
							Suite A #302<br />
							Tacoma, WA 98405
						</span>
					</span>
				</address>

				{hasSocials && (
					<ul class="site-footer__socials">
						{footerSocials.map((social) => (
							<li>
								<a
									href={social.url}
									target="_blank"
									rel="noopener noreferrer"
									title={`Open ${social.name} profile`}
								>
									<Icon name={social.icon} width="22" height="22" />
								</a>
							</li>
						))}
					</ul>
				)}
			</div>

			{hasLists && (
				<nav class="site-footer__nav" aria-label="Footer">
					{footerLists.map((list) => (
						<div class="site-footer__col">
							{list.title && <h6 class="site-footer__col-title">{list.title}</h6>}
							<ul>
								{list.items.map((item) => (
									<li><a href={item.slug}>{item.title}</a></li>
								))}
							</ul>
						</div>
					))}
				</nav>
			)}
		</div>

		<div class="site-footer__bottom">
			<p class="site-footer__copy">
				&copy; {year} {copyrightName}. Licensed Mental Health Counselor in Washington state.
			</p>
			<p class="site-footer__crisis">
				In crisis? Call or text <a href="tel:988">988</a> for the Suicide &amp; Crisis Lifeline.
			</p>
		</div>
	</Container>
</footer>

<style>
	.site-footer {
		margin-top: 0;
		background-color: var(--paper-2);
		color: var(--ink);
		border-top: 1px solid var(--line);
	}

	.site-footer__top {
		display: grid;
		grid-template-columns: 1.3fr 2fr;
		gap: clamp(2rem, 5vw, 5rem);
		padding: clamp(3rem, 6vw, 5rem) 0 3rem;
	}

	.site-footer__brand {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		max-width: 24rem;
	}

	.site-footer__brand :global(.ehc-logo) {
		height: 5.25rem;
	}

	@media (max-width: 820px) {
		.site-footer__brand :global(.ehc-logo) {
			height: 4.5rem;
		}
	}

	.site-footer__contact {
		font-style: normal;
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
		font-size: var(--step-0);
		color: var(--ink-muted);
	}

	.site-footer__contact a,
	.site-footer__address {
		display: inline-flex;
		align-items: flex-start;
		gap: 0.55rem;
		text-decoration: none;
		color: inherit;
		line-height: 1.5;
	}

	.site-footer__contact a:hover {
		color: var(--ink);
	}

	.site-footer__contact :global(iconify-icon) {
		flex-shrink: 0;
		margin-top: 0.18em;
		color: var(--clay-deep);
	}

	.site-footer__socials {
		list-style: none;
		display: flex;
		gap: 0.75rem;
		margin: 0;
		padding: 0;
	}

	.site-footer__socials a {
		display: inline-flex;
		padding: 0.5rem;
		border-radius: var(--radius-pill);
		color: var(--ink);
		border: 1px solid var(--line);
		transition: background-color var(--theme-transition);
	}

	.site-footer__socials a:hover {
		background-color: var(--clay-soft);
	}

	.site-footer__nav {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
		gap: 2rem;
		padding-top: 0.5rem;
	}

	.site-footer__col h6 {
		margin: 0 0 1rem;
	}

	.site-footer__col ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.55rem;
	}

	.site-footer__col a {
		color: var(--ink);
		text-decoration: none;
		font-size: var(--step-0);
		transition: color var(--theme-transition);
	}

	.site-footer__col a:hover {
		color: var(--clay-deep);
		text-decoration: underline;
		text-underline-offset: 0.3em;
		text-decoration-thickness: 1px;
	}

	.site-footer__bottom {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		gap: 0.75rem 2rem;
		padding: 1.5rem 0 2.5rem;
		border-top: 1px solid var(--line);
	}

	.site-footer__copy,
	.site-footer__crisis {
		margin: 0;
		font-size: var(--step--1);
		color: var(--ink-muted);
		max-width: none;
	}

	.site-footer__crisis a {
		color: var(--clay-deep);
		font-weight: 600;
	}

	@media (max-width: 820px) {
		.site-footer__top {
			grid-template-columns: 1fr;
			gap: 2.5rem;
		}

		.site-footer__nav {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 480px) {
		.site-footer__nav {
			grid-template-columns: 1fr;
		}
	}
</style>
