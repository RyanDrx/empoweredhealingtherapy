---
import Button from '../buttons/Button.astro';
import Container from '../Container.astro';
import Icon from '../Icon.astro';
import homeContent from '../../../public/cms/home.json';
---

<section class="home-hero">
	<Container>
		<div class="home-hero__grid">
			<div class="home-hero__text">
				<span class="eyebrow">Meaghan Trezza, LMHC &middot; Tacoma, WA</span>
				<h1 class="home-hero__title">
					<span class="home-hero__title-line">{homeContent.title}</span>
				</h1>
				<p class="lead home-hero__lead">{homeContent.description}</p>

				<ul class="home-hero__chips" aria-label="Practice modalities">
					<li>Somatic Experiencing</li>
					<li>Trauma &amp; anxiety</li>
					<li>Couples &amp; play therapy</li>
					<li>Queer &amp; neurodivergent affirming</li>
				</ul>

				<div class="home-hero__actions">
					<Button href="/contact" customIcon>
						Book a free 15-min consult
						<Fragment slot="icon">
							<Icon name="line-md:chevron-right" />
						</Fragment>
					</Button>
					<Button
						href="https://www.therapyportal.com/p/empowered98403/"
						unelevated
						customIcon
						newTab
					>
						Client portal
						<Fragment slot="icon">
							<Icon name="line-md:external-link-rounded" />
						</Fragment>
					</Button>
				</div>
			</div>

			<figure class="home-hero__figure">
				<img
					width="780"
					height="439"
					id="home-hero-image"
					src="/assets/images/home-hero.webp"
					alt="A quiet, sunlit room — the kind of space therapy often happens in"
					loading="eager"
				/>
				<figcaption class="home-hero__caption">
					In-person in Tacoma. Telehealth across Washington.
				</figcaption>
			</figure>
		</div>
	</Container>
</section>

<style>
	.home-hero {
		padding: clamp(2.5rem, 6vw, 5rem) 0 var(--gap-section);
		position: relative;
	}

	.home-hero__grid {
		display: grid;
		grid-template-columns: 7fr 5fr;
		gap: clamp(2rem, 6vw, 5rem);
		align-items: end;
	}

	.home-hero__text {
		max-width: 36rem;
	}

	.home-hero__title {
		font-size: var(--step-6);
		line-height: 0.98;
		margin: 0 0 1.5rem;
		letter-spacing: -0.025em;
		font-variation-settings: 'opsz' 144, 'SOFT' 30;
	}

	.home-hero__title-line {
		display: inline-block;
		position: relative;
	}

	.home-hero__title-line::after {
		content: '';
		display: block;
		width: 3rem;
		height: 3px;
		background: var(--clay);
		margin-top: 1.5rem;
	}

	.home-hero__lead {
		font-size: var(--step-2);
		line-height: 1.4;
		color: var(--ink-muted);
		font-family: var(--font-display);
		font-style: italic;
		font-variation-settings: 'opsz' 48, 'SOFT' 50;
		font-weight: 400;
		max-width: 30ch;
	}

	.home-hero__chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		list-style: none;
		margin: 1.5rem 0 2rem;
		padding: 0;
	}

	.home-hero__chips li {
		font-size: var(--step--1);
		font-weight: 500;
		padding: 0.4rem 0.85rem;
		border: 1px solid var(--line);
		border-radius: var(--radius-pill);
		color: var(--ink-muted);
		background: oklch(96.5% 0.015 75 / 0.5);
	}

	.home-hero__actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem 1rem;
		margin-top: 1.75rem;
	}

	.home-hero__figure {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.home-hero__figure img {
		width: 100%;
		aspect-ratio: 4 / 5;
		object-fit: cover;
		border-radius: var(--radius-md);
		display: block;
		box-shadow: 0 24px 60px -28px oklch(20% 0.05 50 / 0.35);
	}

	.home-hero__caption {
		font-size: var(--step--1);
		color: var(--ink-faint);
		letter-spacing: 0.04em;
		text-transform: uppercase;
		font-weight: 500;
	}

	@media (max-width: 960px) {
		.home-hero__grid {
			grid-template-columns: 1fr;
			gap: 2.5rem;
		}

		.home-hero__figure img {
			aspect-ratio: 5 / 4;
		}
	}

	@media (max-width: 640px) {
		.home-hero__title-line::after {
			margin-top: 1rem;
		}
		.home-hero__chips {
			margin: 1.25rem 0 1.5rem;
		}
	}
</style>
