---
import settings from '../../config/settings.js';
import ThemeProvider from '../theme-switcher/ThemeProvider.astro';

import '../../styles/index.css';

export interface Props {
	title?: string;
	description?: string;
	canonicalURL?: URL | string;
	image?: string;
}

const title = Astro.props.title || settings.title;
const description = Astro.props.description || settings.description;
const canonicalURL = Astro.props.canonicalURL || new URL(Astro.url.pathname, Astro.site);
const image = new URL(Astro.props.image || '/assets/images/social.png', Astro.site);
const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'MedicalBusiness',
	name: 'Empowered Healing Counseling',
	alternateName: 'Meaghan Trezza, LMHC',
	url: settings.url,
	logo: new URL('/assets/images/EmpoweredHealingLogo.png', Astro.site).href,
	image: image.href,
	description,
	telephone: '+1-360-207-5773',
	address: {
		'@type': 'PostalAddress',
		streetAddress: '1310 South Union Avenue Suite A #302',
		addressLocality: 'Tacoma',
		addressRegion: 'WA',
		postalCode: '98405',
		addressCountry: 'US',
	},
	areaServed: [
		{
			'@type': 'State',
			name: 'Washington',
		},
		{
			'@type': 'City',
			name: 'Tacoma',
		},
	],
	medicalSpecialty: ['MentalHealth', 'Counseling'],
	knowsAbout: [
		'Trauma therapy',
		'Anxiety counseling',
		'Depression counseling',
		'Somatic Experiencing',
		'Play therapy',
		'Couples counseling',
	],
	priceRange: '$$',
};
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width" />
<link rel="icon" type="image/ico" href="/assets/favicon.ico" />
<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="robots" content="index, follow, max-image-preview:large" />
<meta name="author" content="Empowered Healing Counseling" />
<meta name="theme-color" content="#f6f1e8" />
<link rel="canonical" href={canonicalURL} />
<link rel="alternate" type="text/plain" href="/llms.txt" title="LLMs.txt" />
<!-- Generator -->
<meta name="generator" content={Astro.generator} />
<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={image} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={image} />
<meta name="google-site-verification" content="t7iM3OQB3RG4qsZ4pph12u4gMyVEeYn1kiMw3Kud6Bk" />

<!-- For Demonstration of the themes -->
{settings.enableThemeSwitcher && <ThemeProvider />}

<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
