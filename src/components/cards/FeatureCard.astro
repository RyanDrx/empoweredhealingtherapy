---
const { href, imgSrc, title, eyebrow } = Astro.props;
---

<a class="feature-card" href={href}>
	<div class="feature-card__media">
		<img
			width="702"
			height="527"
			src={`${imgSrc}.webp`}
			alt={title}
			loading="lazy"
			decoding="async"
		/>
	</div>
	<div class="feature-card__body">
		{eyebrow && <span class="feature-card__eyebrow">{eyebrow}</span>}
		<h3 class="feature-card__title">{title}</h3>
		<span class="feature-card__cta" aria-hidden="true">Read more &nbsp;&rarr;</span>
	</div>
</a>

<style>
	.feature-card {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		text-decoration: none;
		color: inherit;
		border-radius: var(--radius-md);
	}

	.feature-card__media {
		aspect-ratio: 5 / 4;
		overflow: hidden;
		border-radius: var(--radius-md);
		background: var(--paper-2);
	}

	.feature-card__media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 600ms var(--ease-out-expo),
			filter 600ms var(--ease-out-expo);
	}

	.feature-card:hover .feature-card__media img,
	.feature-card:focus-visible .feature-card__media img {
		transform: scale(1.04);
	}

	.feature-card__body {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		padding: 0 0.15rem;
	}

	.feature-card__eyebrow {
		font-size: var(--step--1);
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--ink-faint);
		font-weight: 500;
	}

	.feature-card__title {
		font-family: var(--font-display);
		font-size: var(--step-2);
		font-weight: 500;
		color: var(--ink);
		margin: 0;
		line-height: 1.2;
		letter-spacing: -0.015em;
	}

	.feature-card__cta {
		font-size: var(--step--1);
		font-weight: 600;
		color: var(--clay-deep);
		margin-top: 0.25rem;
		transition: transform var(--theme-transition);
	}

	.feature-card:hover .feature-card__cta {
		transform: translateX(4px);
	}

	.feature-card:focus-visible {
		outline: 2px solid var(--clay);
		outline-offset: 6px;
	}

	@media (prefers-reduced-motion: reduce) {
		.feature-card__media img,
		.feature-card__cta {
			transition: none;
		}

		.feature-card:hover .feature-card__media img,
		.feature-card:hover .feature-card__cta {
			transform: none;
		}
	}
</style>
